# SplashLens marketing site
# Cloudflare Pages project: poolens-site

# D1 binding configured in Cloudflare Pages, not a plain env var.
# Binding name expected by functions/api/subscribe.js and functions/api/event.js:
SUBSCRIBERS_DB=

# Optional production marker.
ENVIRONMENT=production

# Stripe Payment Links are currently hardcoded in functions/api/checkout.js.
# Prefer env vars before rotating production links:
STRIPE_MONTHLY_LINK=
STRIPE_YEARLY_LINK=

# Restrict /api/subscribe CORS. Comma-separated origins.
SPLASHLENS_ALLOWED_ORIGINS=https://splashlens.com,https://www.splashlens.com,https://poolens-site.pages.dev

# Optional but recommended before public waitlist pushes.
TURNSTILE_SECRET_KEY=
